{
    "name": "queeromaha.com",
    "type": "module",
    "version": "1.0.3",
    "description": "queer stuff in omaha",
    "scripts": {
        "test": "npm-run-all -l -p check test:unit -s test:e2e",
        "test:fast": "run-p -l lint test:data",
        "test:data": "vitest run test/data.test.ts",
        "test:build": "vitest run test/build.test.ts",
        "test:unit": "vitest run",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:a11y": "playwright test test/e2e/a11y.spec.js",
        "dev": "astro dev",
        "start": "astro dev",
        "check": "astro check",
        "serve": "astro dev",
        "build": "astro build",
        "preview": "astro preview",
        "prepare": "husky",
        "lint": "biome check . && bun scripts/format-yaml.js --check",
        "format": "biome check --write . && bun scripts/format-yaml.js",
        "check:links": "bun scripts/check-links.js",
        "check:links:pr": "bun scripts/check-links.js --pr",
        "generate:favicons": "bun run scripts/generate-favicons.mjs"
    },
    "keywords": [],
    "author": "Tara <1711810+taraxvoid@users.noreply.github.com>",
    "license": "MIT",
    "devDependencies": {
        "@astrojs/check": "^0.9.9",
        "@axe-core/playwright": "^4.12.1",
        "@biomejs/biome": "^2.5.2",
        "@playwright/test": "^1.61.1",
        "@types/bun": "^1.3.14",
        "favicons": "^7.3.0",
        "husky": "^9.1.7",
        "npm-run-all2": "^9.0.2",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9",
        "yaml": "^2.9.0"
    },
    "dependencies": {
        "@astrojs/sitemap": "^3.7.3",
        "@awesome.me/webawesome": "^3.10.0",
        "astro": "^7.0.6"
    },
    "volta": {
        "node": "24.15.0"
    }
}
