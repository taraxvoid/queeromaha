{
  "name": "queeromaha.com",
  "version": "1.0.1",
  "author": "Tara <tara.vie@proton.me>",
  "main": "index.js",
  "description": "queer stuff in omaha",
  "keywords": [],
  "license": "MIT",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "serve": "bunx @11ty/eleventy --serve",
    "build": "bunx @11ty/eleventy",
    "approve": "netlify dev:exec -- bun scripts/approve-maker.mjs",
    "generate": "bunx --bun prisma generate --config prisma/prisma.config.ts --schema prisma/schema.prisma",
    "db:migrate": "bunx --bun prisma migrate dev --name init --config prisma/prisma.config.ts --schema prisma/schema.prisma ",
    "db:studio": "bunx --bun prisma studio --config prisma/prisma.config.ts --schema prisma/schema.prisma",
    "db:seed": "bun seed-makers.mjs",
    "deploy": "netlify deploy --prod --dir=./_site"
  },
  "volta": {
    "node": "22.22.2"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0"
  }
}
