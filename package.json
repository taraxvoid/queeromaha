{
    "name": "queeromaha.com",
    "type": "module",
    "version": "1.0.3",
    "description": "queer stuff in omaha",
    "scripts": {
        "test": "bun run build && npm-run-all -l -p check test:unit -s test:e2e:only",
        "test:unit": "vitest run",
        "test:fast": "run-p -l lint test:data",
        "test:data": "vitest run test/data.test.ts",
        "test:ical": "vitest run test/ical.test.ts",
        "test:build": "bun run build && vitest run test/build.test.ts",
        "test:e2e": "bun run build && playwright test --project=mobile-chrome",
        "test:e2e:only": "playwright test --project=mobile-chrome",
        "test:e2e:desktop": "bun run build && playwright test --project=desktop-chrome",
        "test:e2e:all": "bun run build && playwright test",
        "test:e2e:ui": "bun run build && playwright test --ui",
        "test:e2e:headed": "bun run build && playwright test --headed",
        "test:a11y": "bun run build && playwright test test/e2e/a11y.spec.ts --project=mobile-chrome",
        "dev": "astro dev",
        "start": "astro dev",
        "stop": "astro dev stop",
        "check": "astro check",
        "check:content": "astro sync",
        "serve": "astro dev",
        "build": "astro build && bun scripts/generate-redirects.mjs",
        "preview": "astro preview",
        "prepare": "husky",
        "lint": "biome check .",
        "format": "biome check --write . && bun scripts/format-yaml.js",
        "check:links": "bun scripts/check-links.js",
        "check:links:pr": "bun scripts/check-links.js --pr",
        "generate:favicons": "bun run scripts/generate-favicons.mjs",
        "postinstall": "bunx @biomejs/biome migrate --write"
    },
    "keywords": [],
    "author": "Tara <1711810+taraxvoid@users.noreply.github.com>",
    "license": "MIT",
    "devDependencies": {
        "@astrojs/check": "^0.9.9",
        "@axe-core/playwright": "^4.12.1",
        "@biomejs/biome": "^2.5.4",
        "@playwright/test": "^1.61.1",
        "@types/bun": "^1.3.14",
        "favicons": "^7.3.0",
        "happy-dom": "^20.10.6",
        "husky": "^9.1.7",
        "npm-run-all2": "^9.0.2",
        "typescript": "^6.0.3",
        "vitest": "^4.1.10",
        "yaml": "^2.9.0"
    },
    "dependencies": {
        "@astrojs/sitemap": "^3.7.3",
        "@awesome.me/webawesome": "^3.10.0",
        "astro": "^7.0.9"
    },
    "volta": {
        "node": "24.18.0"
    }
}
