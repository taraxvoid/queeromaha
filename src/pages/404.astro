---
import Base from '../layouts/Base.astro'

const redirectSeconds = 8
---

<Base
  title="Page Not Found"
  description="The page you're looking for doesn't exist. Here's how to get back to the Queer Omaha directory."
  refresh={{ seconds: redirectSeconds, url: '/friends' }}
>

  <section class="not-found" aria-label="Page not found">
    <wa-card class="not-found-card">
      <h2 slot="header">
        <wa-icon name="compass" variant="regular" aria-hidden="true"></wa-icon>
        This page wandered off
      </h2>
      <p>We couldn't find that page. It may have moved, been renamed, or never existed.</p>
      <p>
        <a class="not-found-cta" href="/friends" data-notfound-link>Back to the directory</a>
      </p>
      <p class="not-found-countdown" data-notfound-countdown aria-live="polite" hidden>
        Taking you back to the directory in <span data-notfound-seconds>{redirectSeconds}</span>…
      </p>
    </wa-card>
  </section>

  <script>
    import '../scripts/notFoundRedirect'
  </script>

</Base>
