---
import { getCollection } from 'astro:content'
import FilterBar from '../components/FilterBar.astro'
import ItemCard from '../components/ItemCard.astro'
import Base from '../layouts/Base.astro'
import { slugify } from '../utils/slugify'

const categorySlugs = ['social', 'spiritual', 'art', 'cafes', 'music', 'makers']

export async function getStaticPaths() {
    const cats = ['social', 'spiritual', 'art', 'cafes', 'music', 'makers']
    const entries = await getCollection('directory')
    const neighborhoodSlugs = [
        ...new Set(
            entries.flatMap((e) =>
                (e.data.items ?? [])
                    .filter(
                        (i) => i.public !== false && i.location?.neighborhood,
                    )
                    .map((i) => slugify(i.location?.neighborhood ?? ''))
                    .filter(Boolean),
            ),
        ),
    ]

    const paths: { params: { filters: string } }[] = []

    // Single slugs
    for (const s of [...cats, ...neighborhoodSlugs]) {
        paths.push({ params: { filters: s } })
    }
    // Cat + neighborhood combos (both orderings)
    for (const cat of cats) {
        for (const n of neighborhoodSlugs) {
            paths.push({ params: { filters: `${cat}/${n}` } })
        }
    }

    return paths
}

const { filters = '' } = Astro.params
const filterSlugs = filters.split('/').filter(Boolean)
const initialCategories = filterSlugs.filter((s) => categorySlugs.includes(s))

const ORDER = ['social', 'spiritual', 'art', 'cafes', 'music', 'makers']
const entries = await getCollection('directory')
entries.sort((a, b) => ORDER.indexOf(a.id) - ORDER.indexOf(b.id))

const allNeighborhoods: { slug: string; label: string }[] = []
const seenSlugs = new Set<string>()
for (const entry of entries) {
    for (const item of entry.data.items ?? []) {
        if (item.public !== false && item.location?.neighborhood) {
            const slug = slugify(item.location.neighborhood)
            if (!slug) continue
            if (!seenSlugs.has(slug)) {
                seenSlugs.add(slug)
                allNeighborhoods.push({
                    slug,
                    label: item.location.neighborhood,
                })
            }
        }
    }
}

const NEIGHBORHOOD_ORDER = [
    'benson',
    'dundee',
    'midtown',
    'aksarben',
    'downtown',
    'north-o',
    'south-o',
    'west-o',
]
allNeighborhoods.sort((a, b) => {
    const ai = NEIGHBORHOOD_ORDER.indexOf(a.slug)
    const bi = NEIGHBORHOOD_ORDER.indexOf(b.slug)
    if (ai === -1 && bi === -1) return 0
    if (ai === -1) return 1
    if (bi === -1) return -1
    return ai - bi
})

const neighborhoodSlugs = allNeighborhoods.map((n) => n.slug)
const initialNeighborhoods = filterSlugs.filter((s) =>
    neighborhoodSlugs.includes(s),
)

const categoryLabels: Record<string, string> = {
    social: 'Social',
    spiritual: 'Spiritual',
    art: 'Art',
    cafes: 'Cafes',
    music: 'Music',
    makers: 'Makers',
}
---

<Base
  title="Queer Omaha — LGBTQ+ Community Directory"
  description="Community-maintained directory of queer groups, spaces, and resources in Omaha, Nebraska."
  initialCategories={initialCategories}
  initialNeighborhoods={initialNeighborhoods}
>
  <FilterBar neighborhoods={allNeighborhoods} />
  {entries.map(entry => {
    const publicItems = (entry.data.items ?? []).filter(i => i.public !== false)
    if (publicItems.length === 0) return null
    return (
      <section aria-label={categoryLabels[entry.id] ?? entry.id}>
        <h2 class="section-header" data-category-heading={entry.id}>
          {categoryLabels[entry.id] ?? entry.id}
        </h2>
        {publicItems.map(item => (
          <ItemCard item={item} category={entry.id} />
        ))}
      </section>
    )
  })}
</Base>
