---
import { getCollection } from 'astro:content'
import FilterBar from '../components/FilterBar.astro'
import ItemCard from '../components/ItemCard.astro'
import Base from '../layouts/Base.astro'
import { buildNeighborhoods } from '../utils/neighborhoods'
import { slugify } from '../utils/slugify'

const categorySlugs = [
    'friends',
    'spiritual',
    'art',
    'cafes',
    'music',
    'makers',
]

export async function getStaticPaths() {
    const cats = ['friends', 'spiritual', 'art', 'cafes', 'music', 'makers']
    const entries = await getCollection('directory')
    const neighborhoodSlugs = buildNeighborhoods(entries).map((n) => n.slug)

    const paths: { params: { filters: string | undefined } }[] = [
        { params: { filters: undefined } },
    ]

    // Single slugs
    for (const s of [...cats, ...neighborhoodSlugs]) {
        paths.push({ params: { filters: s } })
    }
    // Cat + neighborhood combos (both orderings)
    for (const cat of cats) {
        for (const n of neighborhoodSlugs) {
            paths.push({ params: { filters: `${cat}/${n}` } })
        }
    }

    return paths
}

const { filters = '' } = Astro.params
const filterSlugs = filters.split('/').filter(Boolean)
const effectiveFilterSlugs =
    filterSlugs.length === 0 ? ['friends'] : filterSlugs
const initialCategories = effectiveFilterSlugs.filter((s) =>
    categorySlugs.includes(s),
)

const ORDER = ['friends', 'spiritual', 'art', 'cafes', 'music', 'makers']
const entries = await getCollection('directory')
entries.sort((a, b) => ORDER.indexOf(a.id) - ORDER.indexOf(b.id))

const allNeighborhoods = buildNeighborhoods(entries)

const neighborhoodSlugs = allNeighborhoods.map((n) => n.slug)
const initialNeighborhoods = filterSlugs.filter((s) =>
    neighborhoodSlugs.includes(s),
)

// Mirrors cardMatches() in scripts/filter.ts (category + neighborhood only —
// tags are never part of a static route). This lets the server render the
// same hidden state filter.ts would apply on load, so there's no flash of
// the full unfiltered directory before JS hides it (a major CLS source).
function matchesInitial(
    item: NonNullable<(typeof entries)[number]['data']['items']>[number],
    catId: string,
) {
    const catOk =
        initialCategories.length === 0 || initialCategories.includes(catId)
    const nbrSlug = item.location?.neighborhood
        ? slugify(item.location.neighborhood)
        : ''
    const nbrOk =
        initialNeighborhoods.length === 0 ||
        initialNeighborhoods.includes(nbrSlug)
    return catOk && nbrOk
}

const categoryLabels: Record<string, string> = {
    friends: 'Friends',
    spiritual: 'Spiritual',
    art: 'Art',
    cafes: 'Cafes',
    music: 'Music',
    makers: 'Makers',
}

const categoryIcons: Record<string, string> = {
    friends: 'people-group',
    spiritual: 'lotus',
    art: 'palette',
    cafes: 'mug-saucer',
    music: 'music',
    makers: 'hammer',
}
---

<Base
  title="Queer Omaha — LGBTQ+ Community Directory"
  description="Community-maintained directory of queer groups, spaces, and resources in Omaha, Nebraska."
  initialCategories={initialCategories}
  initialNeighborhoods={initialNeighborhoods}
>
  <FilterBar neighborhoods={allNeighborhoods} />
  {entries.map(entry => {
    const publicItems = (entry.data.items ?? []).filter(i => i.public !== false)
    if (publicItems.length === 0) return null
    const anyVisible = publicItems.some(item => matchesInitial(item, entry.id))
    return (
      <section id={`section-${entry.id}`} aria-label={categoryLabels[entry.id] ?? entry.id}>
        <h2 class="section-header" data-category-heading={entry.id} hidden={!anyVisible}>
          <wa-icon name={categoryIcons[entry.id]} aria-hidden="true"></wa-icon> {categoryLabels[entry.id] ?? entry.id}
        </h2>
        {publicItems.map(item => (
          <ItemCard item={item} category={entry.id} hidden={!matchesInitial(item, entry.id)} />
        ))}
      </section>
    )
  })}
</Base>
