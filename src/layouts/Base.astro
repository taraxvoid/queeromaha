---
import footerMessages from '../data/footerMessages.json'
import site from '../data/site.json'
import '../styles/theme.css'
import HeadMeta from '../components/HeadMeta.astro'
import SiteFooter from '../components/SiteFooter.astro'
import SiteHeader from '../components/SiteHeader.astro'

interface Props {
    title?: string
    description?: string
    initialCategories?: string[]
    initialTags?: string[]
    refresh?: { seconds: number; url: string }
}

const {
    title,
    description,
    initialCategories = [],
    initialTags = [],
    refresh,
} = Astro.props
const pageTitle = title ? `${title} | Queer Omaha` : 'Queer Omaha'
const canonicalUrl = new URL(Astro.url.pathname, site.url).href
const randomMsg =
    footerMessages.messages[
        Math.floor(Math.random() * footerMessages.messages.length)
    ]
---

<!doctype html>
<html lang="en">
  <HeadMeta title={pageTitle} description={description} canonicalUrl={canonicalUrl} refresh={refresh} />
  <body
    data-initial-categories={initialCategories.join(' ')}
    data-initial-tags={initialTags.join(' ')}
  >
    <SiteHeader />
    <main id="main" tabindex="-1">
      {title && <h1 class="wa-visually-hidden">{title}</h1>}
      <slot />
    </main>
    <SiteFooter message={randomMsg.text} />
    <script>
      import '@awesome.me/webawesome/dist/components/button/button.js'
      import '@awesome.me/webawesome/dist/components/card/card.js'
      import '@awesome.me/webawesome/dist/components/icon/icon.js'
      import '@awesome.me/webawesome/dist/components/tooltip/tooltip.js'
      import '../scripts/filter'

      // On a cold load landing directly on a hash (e.g. /about#suggest),
      // the browser's native fragment scroll can run before these Web
      // Awesome imports resolve and the header grows taller, leaving the
      // scroll position short. Re-settle once the custom elements are
      // defined; scrollIntoView respects theme.css's scroll-padding-top.
      if (location.hash) {
        Promise.all([
          customElements.whenDefined('wa-button'),
          customElements.whenDefined('wa-icon'),
        ]).then(() => {
          document.getElementById(location.hash.slice(1))?.scrollIntoView({ block: 'start' })
        })
      }
    </script>
  </body>
</html>
