---
interface Props {
    label: string
    icon: string
    family?: string
}
const { label, icon, family } = Astro.props
const id = `et-${crypto.randomUUID()}`
---

<span class="et" title={label} role="img" aria-label={label}><wa-icon name={icon} family={family} aria-hidden="true"></wa-icon></span
><wa-tooltip for={id} aria-hidden>{label}</wa-tooltip><span
    {id}
    class="et-enhanced"
    role="img"
    aria-label={label}><wa-icon name={icon} family={family} aria-hidden="true"></wa-icon></span
>
<style>
    /* Hides wa-tooltip after web awesome script loads */
    .et:has(+ wa-tooltip:defined) {
        display: none;
    }

    /* Hides wa-tooltip until web awesome script loads */
    wa-tooltip:not(:defined) {
        &,
        & + .et-enhanced {
            display: none;
        }
    }

    .et,
    .et-enhanced {
        margin-left: 0.35rem;
        font-size: 1rem;
        color: #7c3aed;
        vertical-align: text-bottom;
        position: relative;
        top: -0.15em;
    }
</style>
