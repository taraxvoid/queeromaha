---
---

<header>
  <a class="skip-link" href="#main">Skip to main content</a>
  <nav class="main-nav" aria-label="Main navigation">
    <wa-button href="/friends" appearance="plain" data-filter="friends" data-filter-type="category" aria-pressed="false">
      <wa-icon name="people-group" aria-hidden="true"></wa-icon> Friends
    </wa-button>
    <wa-button href="/spiritual" appearance="plain" data-filter="spiritual" data-filter-type="category" aria-pressed="false">
      <wa-icon name="lotus" aria-hidden="true"></wa-icon> Spiritual
    </wa-button>
    <wa-button href="/art" appearance="plain" data-filter="art" data-filter-type="category" aria-pressed="false">
      <wa-icon name="palette" aria-hidden="true"></wa-icon> Art
    </wa-button>
    <wa-button href="/cafes" appearance="plain" data-filter="cafes" data-filter-type="category" aria-pressed="false">
      <wa-icon name="mug-saucer" aria-hidden="true"></wa-icon> Cafes
    </wa-button>
    <wa-button href="/music" appearance="plain" data-filter="music" data-filter-type="category" aria-pressed="false">
      <wa-icon name="music" aria-hidden="true"></wa-icon> Music
    </wa-button>
    <wa-button href="/makers" appearance="plain" data-filter="makers" data-filter-type="category" aria-pressed="false">
      <wa-icon name="paintbrush" aria-hidden="true"></wa-icon> Makers
    </wa-button>
  </nav>
</header>
<script>
  import { prefetch } from 'astro:prefetch'

  const navBtns = document.querySelectorAll('.main-nav wa-button')
  const currentPath = window.location.pathname.replace(/\/$/, '') || '/'
  let hoverTimeout

  navBtns.forEach((btn) => {
    const rawHref = btn.getAttribute('href')
    const href = (rawHref ?? '').replace(/\/$/, '') || '/'
    const isActive = href === currentPath
    if (isActive) {
      btn.classList.add('active')
      btn.setAttribute('aria-current', 'page')
      return
    }
    if (!rawHref) return

    // Astro's built-in prefetch only listens on real <a> tags, and these
    // are <wa-button href> custom elements, so it never picks them up.
    // Wire the same hover-intent/tap timing Astro uses internally
    // (astro/dist/prefetch/index.js) directly to the pills instead.
    const startHoverPrefetch = () => {
      clearTimeout(hoverTimeout)
      hoverTimeout = setTimeout(() => prefetch(rawHref), 80)
    }
    const cancelHoverPrefetch = () => clearTimeout(hoverTimeout)
    const startTapPrefetch = () => prefetch(rawHref, { ignoreSlowConnection: true })

    btn.addEventListener('pointerenter', startHoverPrefetch)
    btn.addEventListener('focus', startHoverPrefetch)
    btn.addEventListener('pointerleave', cancelHoverPrefetch)
    btn.addEventListener('blur', cancelHoverPrefetch)
    btn.addEventListener('touchstart', startTapPrefetch, { passive: true })
    btn.addEventListener('mousedown', startTapPrefetch)
  })

  // The sticky header's height varies by breakpoint (nav pills wrap) and
  // grows once the wa-button/wa-icon custom elements upgrade, so track it
  // live in a CSS var used by theme.css's scroll-padding-top rule instead
  // of hardcoding an offset for anchor-linked sections (e.g. /about#suggest).
  const headerEl = document.querySelector('header')
  if (headerEl) {
    const setHeaderHeightVar = () =>
      document.documentElement.style.setProperty(
        '--header-height',
        `${headerEl.getBoundingClientRect().height}px`,
      )
    setHeaderHeightVar()
    new ResizeObserver(setHeaderHeightVar).observe(headerEl)
  }
</script>
