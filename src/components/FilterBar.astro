---
import tagMap from '../data/tagMap.json'

interface Props {
    neighborhoods?: { slug: string; label: string }[]
}

const { neighborhoods = [] } = Astro.props

const tags = Object.entries(
    tagMap as Record<string, { emoji: string; label: string }>,
).map(([slug, { emoji, label }]) => ({ slug, emoji, label }))
---

<div class="filter-bar" role="group" aria-label="Filter by neighborhood or tag">
  {neighborhoods.length > 0 && (
    <div class="filter-pills filter-pills--neighborhoods">
      <button class="filter-clear" id="filterClear" aria-label="Clear filters" disabled>
        ✕ Clear
      </button>
      {neighborhoods.map(({ slug, label }) => (
        <button
          class="filter-pill"
          data-filter={slug}
          data-filter-type="neighborhood"
          aria-pressed="false"
        >
          {label}
        </button>
      ))}
    </div>
  )}
  <div class="filter-pills filter-pills--tags">
    {neighborhoods.length === 0 && (
      <button class="filter-clear" id="filterClear" aria-label="Clear filters" disabled>
        ✕ Clear
      </button>
    )}
    {tags.map(({ slug, emoji, label }) => (
      <button
        class="filter-pill"
        data-filter={slug}
        data-filter-type="tag"
        aria-pressed="false"
      >
        {emoji} {label}
      </button>
    ))}
  </div>
</div>
