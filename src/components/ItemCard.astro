---
import { marked } from 'marked'
import type { z } from 'zod'
import type { itemSchema } from '../content.config'
import tagMap from '../data/tagMap.json'
import { slugify } from '../utils/slugify'
import EntryTag from './EntryTag.astro'

type TagMap = Record<string, { icon: string; label: string }>
const tags = tagMap as TagMap

interface Props {
    item: z.infer<typeof itemSchema>
    category: string
}

const { item, category } = Astro.props
const descHtml = item.description ? marked.parse(item.description) : ''
const tagsAttr = item.tags?.join(' ') ?? ''

const loc = item.location
const neighborhoodSlug = loc?.neighborhood ? slugify(loc.neighborhood) : ''
const addrParts = [
    loc?.street,
    loc?.city,
    loc?.state && loc?.zip
        ? `${loc.state} ${loc.zip}`
        : (loc?.state ?? loc?.zip),
].filter(Boolean)
const addrLine = addrParts.join(', ')
const locLine = [addrLine, loc?.neighborhood].filter(Boolean).join(' - ')

// Per-item structured data. As of 2026 schema.org markup — not llms.txt — is
// what assistants and answer engines actually read when deciding which local
// entities to surface. We emit Organization (the truthful supertype across
// support groups, venues, and cafes alike) rather than LocalBusiness, which
// would assert a "this is a business" claim we can't verify for every entry.
const itemLinks = item.links?.map((l) => l.url) ?? []
const postalAddress =
    loc?.street || loc?.city || loc?.state || loc?.zip
        ? {
              '@type': 'PostalAddress',
              ...(loc?.street && { streetAddress: loc.street }),
              ...(loc?.city && { addressLocality: loc.city }),
              ...(loc?.state && { addressRegion: loc.state }),
              ...(loc?.zip && { postalCode: loc.zip }),
          }
        : undefined
const plainDesc = descHtml
    ? String(descHtml)
          .replace(/<[^>]+>/g, '')
          .replace(/&amp;/g, '&')
          .replace(/&lt;/g, '<')
          .replace(/&gt;/g, '>')
          .replace(/&quot;/g, '"')
          .replace(/&#39;/g, "'")
          .replace(/\s+/g, ' ')
          .trim()
    : ''
const jsonLd = {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: item.name,
    ...(plainDesc && { description: plainDesc }),
    ...(itemLinks.length > 0 && { sameAs: itemLinks }),
    ...(postalAddress && { address: postalAddress }),
    ...(loc?.google_maps_url && { hasMap: loc.google_maps_url }),
}
// Escape `<` so a stray "</script>" in any field can't break out of the tag.
const jsonLdStr = JSON.stringify(jsonLd).replace(/</g, '\\u003c')
---

<script is:inline type="application/ld+json" set:html={jsonLdStr} />
<wa-card class="item" data-category={category} data-tags={tagsAttr} data-neighborhood={neighborhoodSlug}>
  <h3 slot="header">
    {item.name}
    {item.tags?.map(tag => {
      const t = tags[tag]
      return t ? (
        <EntryTag label={t.label} icon={t.icon} />
      ) : null
    })}
  </h3>
  {descHtml && <Fragment set:html={descHtml} />}
  {loc && locLine && (
    <p class="item-location">
      <wa-icon name="location-dot" aria-hidden="true"></wa-icon>
      {loc.google_maps_url ? (
        <a href={loc.google_maps_url} rel="noopener noreferrer" target="_blank" aria-label={`Map: ${locLine} (opens in new tab)`}>
          {locLine}
        </a>
      ) : (
        locLine
      )}
    </p>
  )}
  {item.links && item.links.length > 0 && (
    <ul class="entry-links" slot="footer">
      {item.links.map(link => {
        const url = link.url.toLowerCase()
        const label = link.label.toLowerCase()
        let pillIcon: { name: string; family: string } | null = null
        if (url.includes('instagram.com')) {
          pillIcon = { name: 'instagram', family: 'brands' }
        } else if (url.includes('facebook.com')) {
          pillIcon = { name: 'facebook', family: 'brands' }
        } else if (url.includes('discord.com') || url.includes('discord.gg')) {
          pillIcon = { name: 'discord', family: 'brands' }
        } else if (url.includes('carrd.co')) {
          pillIcon = { name: 'rectangle-list', family: 'classic' }
        } else if (label.includes('website')) {
          pillIcon = { name: 'earth-africa', family: 'classic' }
        } else if (label.includes('event') || label.includes('calendar')) {
          pillIcon = { name: 'calendar', family: 'classic' }
        } else if (label.includes('register') || label.includes('signup')) {
          pillIcon = { name: 'square-check', family: 'classic' }
        } else if (label.includes('clothes') || label.includes('closet')) {
          pillIcon = { name: 'person-half-dress', family: 'classic' }
        } else if (label.includes('pantry') || label.includes('food')) {
          pillIcon = { name: 'jar', family: 'classic' }
        }
        return (
          <li>
            <a href={link.url} rel="noopener noreferrer" target="_blank" aria-label={`${link.label} (opens in new tab)`}>
              {pillIcon && <wa-icon name={pillIcon.name} family={pillIcon.family} aria-hidden="true"></wa-icon>}
              {link.label}
            </a>
          </li>
        )
      })}
    </ul>
  )}
</wa-card>
