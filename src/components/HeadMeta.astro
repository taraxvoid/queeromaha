---

interface Props {
    title: string
    description?: string
    canonicalUrl: string
    refresh?: { seconds: number; url: string }
}

const { title, description, canonicalUrl, refresh } = Astro.props
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  {refresh && <meta http-equiv="refresh" content={`${refresh.seconds};url=${refresh.url}`} />}
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="preconnect" href="https://ka-f.fontawesome.com" crossorigin />
  <meta name="theme-color" content="#4c3170" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="Queer Omaha" />
  <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
  <link rel="alternate" type="text/calendar" href="/events.ics" title="Queer Omaha Events" />
  {description && <meta name="description" content={description} />}
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Queer Omaha" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: "Queer Omaha",
      url: site.url,
      description: "Community-maintained directory of queer groups, spaces, and resources in Omaha, Nebraska.",
    })}>
  </script>
  <script is:inline>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js')
    }
  </script>
</head>
