---
interface Props {
    message: string
}

const { message } = Astro.props
---

<footer>
  <details class="suggestion-box" id="suggestionBox" name="footer-accordion">
    <summary class="footer-pill-btn"
      ><wa-icon name="lightbulb" variant="regular" aria-hidden="true"></wa-icon>Suggestion Box</summary
    >
    <div class="suggestion-box-panel">
      <form id="suggestForm" name="suggest" method="POST" data-netlify="true" data-netlify-honeypot="bot-field">
        <p class="suggestion-honeypot">
          <label>Don't fill this out if you're human: <input name="bot-field" /></label>
        </p>
        <label class="suggestion-label" for="suggestionMessage"
          >Suggest a place, group, or event to add</label
        >
        <input
          id="suggestionMessage"
          class="suggestion-input"
          type="text"
          name="message"
          required
          maxlength="140"
          enterkeyhint="send"
          aria-describedby="suggestionHint"
          placeholder="What should we add?"
        />
        <p class="suggestion-hint" id="suggestionHint">Up to 140 characters</p>
      </form>
    </div>
    <div class="suggestion-box-toggle-row">
      <button class="suggestion-submit" type="submit" form="suggestForm">Send</button>
    </div>
  </details>
  <details class="calendar-box" id="calendarBox" name="footer-accordion">
    <summary class="footer-pill-btn"
      ><wa-icon name="calendar" variant="regular" aria-hidden="true"></wa-icon><span class="footer-cal-label">Gay Agenda</span></summary
    >
    <div class="calendar-box-panel">
      <a
        class="calendar-option"
        href="https://calendar.google.com/calendar/r?cid=webcal%3A%2F%2Fqueeromaha.net%2Fevents.ics"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Subscribe to the Queer Omaha Events calendar in Google Calendar"
      >
        <wa-icon family="brands" name="google" aria-hidden="true"></wa-icon>Google Calendar
      </a>
      <a
        class="calendar-option"
        href="webcal://queeromaha.net/events.ics"
        aria-label="Add to Calendar (Apple Calendar and other calendar apps)"
      >
        <wa-icon family="brands" name="apple" aria-hidden="true"></wa-icon>Add to Calendar
      </a>
    </div>
  </details>
  <span class="footer-separator footer-separator-left" aria-hidden="true"></span>
  <div class="footer-text">
    <p class="footer-message">{message}</p>
  </div>
  <span class="footer-separator footer-separator-right" aria-hidden="true"></span>
  <nav class="footer-nav" aria-label="Footer navigation">
    <a
      href="https://analytics.queeromaha.net/redirect/github"
      aria-label="@taraxvoid/queeromaha on GitHub (opens in new tab)"
      class="footer-icon"
      rel="noopener noreferrer"
      target="_blank"
    >
      <wa-icon family="brands" name="github" label="GitHub"></wa-icon>
    </a>
  </nav>
</footer>
<button id="backToTop" aria-label="Back to top">
  <wa-icon name="circle-arrow-up" variant="solid"></wa-icon>
</button>
<script>
  import '../scripts/suggestionBox'
  import '../scripts/calendarBox'

  const footerText = document.querySelector<HTMLElement>('.footer-text')
  const footerMessage = document.querySelector<HTMLElement>('.footer-message')
  if (footerText && footerMessage) {
    const checkFooterFit = () => {
      footerText.hidden = false
      footerText.hidden = footerMessage.scrollWidth > footerMessage.clientWidth
    }
    checkFooterFit()
    let lastWidth = window.innerWidth
    window.addEventListener('resize', () => {
      if (window.innerWidth !== lastWidth) {
        lastWidth = window.innerWidth
        checkFooterFit()
      }
    })
  }

  const backToTopButton = document.getElementById('backToTop')
  const header = document.querySelector('header')
  if (backToTopButton && header) {
    window.addEventListener('scroll', () => {
      backToTopButton.classList.toggle('show', window.scrollY > header.offsetHeight)
    })
    backToTopButton.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' })
    })
  }
</script>
