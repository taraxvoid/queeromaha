<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} | {% endif %}Queer Omaha</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>
  <header>
    <nav>
      <a href="/home">Home</a>
      <a href="/art">Art</a>
      <a href="/cafes">Cafes</a>
      <a href="/music">Music</a>
      <a href="/makers">Makers</a>
    </nav>
  </header>
  <main>
    {% if intro %}
      {{ intro | markdown | safe }}
    {% endif %}
    {% if items %}
      {% for entry in items %}
        {% if entry.type == 'section' %}
          <a id="{{ entry.id }}"></a>
          <h2 class="section-header">{{ entry.label }}</h2>
          {% if entry.note %}{{ entry.note | markdown | safe }}{% endif %}
        {% elif entry.public != false %}
          <div class="item">
            <h3>{{ entry.name }}{% if entry.tags %}{% for tag in entry.tags %}{% if tagMap[tag] %} <span title="{{ tagMap[tag].label }}">{{ tagMap[tag].emoji }}</span>{% endif %}{% endfor %}{% endif %}</h3>
            {% if entry.description %}{{ entry.description | markdown | safe }}{% endif %}
            {% if entry.links %}<p>{% for link in entry.links %}{% if not loop.first %} | {% endif %}<a href="{{ link.url }}">{{ link.label }}</a>{% endfor %}</p>{% endif %}
          </div>
        {% endif %}
      {% endfor %}
      {% if content %}{{ content | safe }}{% endif %}
    {% else %}
      {{ content | safe }}
    {% endif %}
  </main>
   <footer>
    <a href="/contact">Contact</a>
    <p>
      {%- set randomMsg = footerMessages.messages[range(0, footerMessages.messages.length) | random] %}
      {{ randomMsg.text }}
    </p>
    <a href="/about">About</a>
  </footer>
  <div id="disclaimer">
    <p>inclusion on this site does not imply endorsement</p>
  </div>
  <button id="backToTop" aria-label="Back to top"><i class="bi bi-arrow-up-circle"></i></button>
  <script>
    // Emoji tooltip mapping
    const emojiMap = {
      '🚻': 'Gender-neutral bathroom',
      '🛋️': 'Seating available',
      '💻': 'Work/study spot',
      '🏳️‍🌈': 'Queer owned',
    };

    // Wrap emojis with tooltips
    document.addEventListener('DOMContentLoaded', function() {
      const main = document.querySelector('main');
      if (!main) return;

      // Process the entire main content
      let html = main.innerHTML;
      
      // Replace each emoji with wrapped version
      for (const [emoji, description] of Object.entries(emojiMap)) {
        const wrapped = `<span title="${description}">${emoji}</span>`;
        html = html.split(emoji).join(wrapped);
      }
      
      main.innerHTML = html;

      // Open external links in new tab (without switching focus)
      const mainLinks = document.querySelectorAll('main a');
      mainLinks.forEach(link => {
        const href = link.getAttribute('href');
        // Open external links in new tab (those that start with http/https or mailto)
        if (href && (href.startsWith('http://') || href.startsWith('https://') || href.startsWith('mailto:'))) {
          link.addEventListener('click', function(e) {
            e.preventDefault();
            window.open(href, '_blank');
          });
          link.setAttribute('rel', 'noopener noreferrer');
        }
      });

      // Highlight the current page's nav link
      const links = document.querySelectorAll('nav a');
      const currentPath = window.location.pathname;
      links.forEach(link => {
        if (link.pathname === currentPath || link.pathname === currentPath.replace(/\/$/, '')) {
          link.classList.add('active');
        }
      });

      // Back to top button
      const backToTopButton = document.getElementById('backToTop');
      const header = document.querySelector('header');
      
      window.addEventListener('scroll', function() {
        const headerBottom = header.offsetHeight;
        if (window.scrollY > headerBottom) {
          backToTopButton.classList.add('show');
        } else {
          backToTopButton.classList.remove('show');
        }
      });
      
      backToTopButton.addEventListener('click', function() {
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      });
    });

    if (window.netlifyIdentity) {
      window.netlifyIdentity.on('init', function(user) {
        if (!user) {
          window.netlifyIdentity.on('login', function() {
            document.location.href = '/admin/';
          });
        }
      });
    }
  </script>
</body>
</html>
