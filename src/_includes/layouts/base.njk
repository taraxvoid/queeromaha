<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} | {% endif %}Queer Omaha</title>
  <link rel="stylesheet" href="https://ka-f.webawesome.com/webawesome@3.7.0/styles/webawesome.css" />
  <link rel="stylesheet" href="/css/theme.css">
  <script type="module" src="https://ka-f.webawesome.com/webawesome@3.7.0/webawesome.loader.js"></script>
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
  {% if description %}<meta name="description" content="{{ description }}" />{% endif %}
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Queer Omaha" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  <meta property="og:title" content="{% if title %}{{ title }} | {% endif %}Queer Omaha" />
  {% if description %}<meta property="og:description" content="{{ description }}" />{% endif %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Queer Omaha",
    "url": "{{ site.url }}",
    "description": "Community-maintained directory of queer groups, spaces, and resources in Omaha, Nebraska."
  }
  </script>
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>
  <a class="skip-link" href="#main">Skip to main content</a>
  <header>
    <nav class="main-nav" aria-label="Main navigation">
      <wa-button href="/" appearance="plain">Home</wa-button>
      <wa-button href="/art" appearance="plain">Art</wa-button>
      <wa-button href="/cafes" appearance="plain">Cafes</wa-button>
      <wa-button href="/music" appearance="plain">Music</wa-button>
      <wa-button href="/makers" appearance="plain">Makers</wa-button>
    </nav>
  </header>
  <main id="main" tabindex="-1">
    {% if title %}<h1 class="wa-visually-hidden">{{ title }}</h1>{% endif %}
    {% if items %}
      {% for entry in items %}
        {% if entry.type == 'section' %}
          <h2 id="{{ entry.id }}" class="section-header">{{ entry.label }}</h2>
          {% if entry.note %}{{ entry.note | markdown | safe }}{% endif %}
        {% elif entry.public != false %}
          <wa-card class="item">
            <h3 slot="header">{{ entry.name }}{% if entry.tags %}{% for tag in entry.tags %}{% if tagMap[tag] %} <span role="img" aria-label="{{ tagMap[tag].label }}" title="{{ tagMap[tag].label }}">{{ tagMap[tag].emoji }}</span>{% endif %}{% endfor %}{% endif %}</h3>
            {% if entry.description %}{{ entry.description | markdown | safe }}{% endif %}
            {% if entry.links %}<ul class="entry-links" slot="footer">{% for link in entry.links %}<li><a href="{{ link.url }}" rel="noopener noreferrer" target="_blank" aria-label="{{ link.label }} (opens in new tab)">{{ link.label }}</a></li>{% endfor %}</ul>{% endif %}
          </wa-card>
        {% endif %}
      {% endfor %}
      {% if content %}{{ content | safe }}{% endif %}
    {% else %}
      {{ content | safe }}
    {% endif %}
  </main>
  <footer>
    <div class="footer-text">
      <p class="footer-message">
        {%- set randomMsg = footerMessages.messages[range(0, footerMessages.messages.length) | random] %}
        {{ randomMsg.text }}
      </p>
      
    </div>
    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="/contact">Contact</a>
      <a href="/about">About</a>
      <a href="https://github.com/taraxvoid/queeromaha" aria-label="GitHub (opens in new tab)" class="footer-icon" rel="noopener noreferrer" target="_blank"><wa-icon family="brands" name="github" label="GitHub"></wa-icon></a>
    </nav>
  </footer>
  <button id="backToTop" aria-label="Back to top"><wa-icon name="circle-arrow-up" variant="solid"></wa-icon></button>
  <script>
    // Emoji tooltip mapping
    const emojiMap = {
      '🚻': 'Gender-neutral bathroom',
      '🛋️': 'Seating available',
      '💻': 'Work/study spot',
      '🏳️‍🌈': 'Queer owned',
    };

    // Wrap emojis with tooltips
    document.addEventListener('DOMContentLoaded', function() {
      const main = document.querySelector('main');
      if (!main) return;

      // Process the entire main content
      let html = main.innerHTML;
      
      let tipIdx = 0;
      for (const [emoji, description] of Object.entries(emojiMap)) {
        const parts = html.split(emoji);
        if (parts.length > 1) {
          let rebuilt = parts[0];
          for (let i = 1; i < parts.length; i++) {
            const id = `et${tipIdx++}`;
            rebuilt += `<wa-tooltip for="${id}">${description}</wa-tooltip><span id="${id}" role="img" aria-label="${description}">${emoji}</span>` + parts[i];
          }
          html = rebuilt;
        }
      }

      main.innerHTML = html;

      // Highlight the current page's nav link
      const navBtns = document.querySelectorAll('.main-nav wa-button');
      const currentPath = window.location.pathname.replace(/\/$/, '') || '/';
      navBtns.forEach(btn => {
        const href = (btn.getAttribute('href') || '').replace(/\/$/, '') || '/';
        if (href === currentPath) {
          btn.classList.add('active');
          btn.setAttribute('aria-current', 'page');
        }
      });

      // Back to top button
      const backToTopButton = document.getElementById('backToTop');
      const header = document.querySelector('header');
      
      window.addEventListener('scroll', function() {
        const headerBottom = header.offsetHeight;
        if (window.scrollY > headerBottom) {
          backToTopButton.classList.add('show');
        } else {
          backToTopButton.classList.remove('show');
        }
      });
      
      backToTopButton.addEventListener('click', function() {
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      });
    });

    if (window.netlifyIdentity) {
      window.netlifyIdentity.on('init', function(user) {
        var hash = window.location.hash;
        if (hash && (hash.includes('confirmation_token') || hash.includes('recovery_token') || hash.includes('invite_token'))) {
          window.netlifyIdentity.open();
        }
        if (!user) {
          window.netlifyIdentity.on('login', function() {
            document.location.href = '/admin/';
          });
        }
      });
    }
  </script>
</body>
</html>
