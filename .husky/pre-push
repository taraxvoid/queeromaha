has_new_commits=false
while read local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" != "$remote_sha" ]; then
    has_new_commits=true
  fi
done

if [ "$has_new_commits" = false ]; then
  echo "pre-push: no new commits to push, skipping checks"
  exit 0
fi

# run astro check and tests in parallel; both must pass
bun run check &
CHECK_PID=$!
bun run test
TEST_EXIT=$?
wait $CHECK_PID
CHECK_EXIT=$?
[ $TEST_EXIT -ne 0 ] || [ $CHECK_EXIT -ne 0 ] && exit 1
exit 0
